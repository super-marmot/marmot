{
  "cli": {
    "version": ">=21.0.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "track": "internal",
        "releaseStatus": "completed"
      },
      "ios": {}
    },
    "production": {
      "android": {
        "track": "production",
        "releaseStatus": "completed"
      },
      "ios": {}
    }
  }
}
